<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_library_book_form" model="ir.ui.view">
        <field name="name">vidya.library.book.form</field>
        <field name="model">vidya.library.book</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_1920'}"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" string="Book Title"/>
                        <h1>
                            <field name="name" placeholder="e.g. The Great Gatsby"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="author"/>
                            <field name="category_id"/>
                            <field name="publisher"/>
                            <field name="edition"/>
                        </group>
                        <group>
                            <field name="isbn"/>
                            <field name="barcode"/>
                            <field name="location"/>
                            <field name="total_copies"/>
                            <field name="available_copies"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_library_book_tree" model="ir.ui.view">
        <field name="name">vidya.library.book.tree</field>
        <field name="model">vidya.library.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="author"/>
                <field name="category_id"/>
                <field name="isbn"/>
                <field name="available_copies"/>
                <field name="total_copies"/>
            </list>
        </field>
    </record>
    
    <record id="view_vidya_library_book_kanban" model="ir.ui.view">
        <field name="name">vidya.library.book.kanban</field>
        <field name="model">vidya.library.book</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="id"/>
                <field name="name"/>
                <field name="author"/>
                <field name="available_copies"/>
                <field name="image_1920"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('vidya.library.book', 'image_1920', record.id.raw_value)" alt="Book cover"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="o_kanban_tags_section">
                                    <span class="badge rounded-pill text-bg-primary">
                                        <field name="available_copies"/> Available
                                    </span>
                                </div>
                                <ul>
                                    <li>Author: <field name="author"/></li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_vidya_library_book" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">vidya.library.book</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
