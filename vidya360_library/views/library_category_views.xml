<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_library_category_form" model="ir.ui.view">
        <field name="name">vidya.library.category.form</field>
        <field name="model">vidya.library.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Science Fiction"/>
                        </h1>
                    </div>
                    <group>
                        <field name="description"/>
                        <field name="active" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_library_category_tree" model="ir.ui.view">
        <field name="name">vidya.library.category.tree</field>
        <field name="model">vidya.library.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_library_category" model="ir.actions.act_window">
        <field name="name">Book Categories</field>
        <field name="res_model">vidya.library.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
