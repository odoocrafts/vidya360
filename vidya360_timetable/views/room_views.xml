<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_room_form" model="ir.ui.view">
        <field name="name">vidya.room.form</field>
        <field name="model">vidya.room</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="room_type"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_room_tree" model="ir.ui.view">
        <field name="name">vidya.room.tree</field>
        <field name="model">vidya.room</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="room_type"/>
                <field name="capacity"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_room" model="ir.actions.act_window">
        <field name="name">Rooms / Labs</field>
        <field name="res_model">vidya.room</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vidya360_room" name="Rooms" parent="menu_vidya360_timetable_config" action="action_vidya_room" sequence="10"/>
</odoo>
