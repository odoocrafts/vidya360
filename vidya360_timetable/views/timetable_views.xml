<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_timetable_form" model="ir.ui.view">
        <field name="name">vidya.timetable.form</field>
        <field name="model">vidya.timetable</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="academic_year_id"/>
                            <field name="term_id"/>
                        </group>
                        <group>
                            <field name="class_id"/>
                            <field name="section_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Schedule">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="day_of_week"/>
                                    <field name="period_id"/>
                                    <field name="subject_id"/>
                                    <field name="teacher_id"/>
                                    <field name="room_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_timetable_tree" model="ir.ui.view">
        <field name="name">vidya.timetable.tree</field>
        <field name="model">vidya.timetable</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="academic_year_id"/>
                <field name="class_id"/>
                <field name="section_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_timetable" model="ir.actions.act_window">
        <field name="name">Class Timetables</field>
        <field name="res_model">vidya.timetable</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vidya360_timetable" name="Class Timetables" parent="menu_vidya360_timetable_schedules" action="action_vidya_timetable" sequence="10"/>
</odoo>
