<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_period_form" model="ir.ui.view">
        <field name="name">vidya.period.form</field>
        <field name="model">vidya.period</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                            <field name="is_break"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_period_tree" model="ir.ui.view">
        <field name="name">vidya.period.tree</field>
        <field name="model">vidya.period</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
                <field name="is_break"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_period" model="ir.actions.act_window">
        <field name="name">Periods</field>
        <field name="res_model">vidya.period</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vidya360_period" name="Periods" parent="menu_vidya360_timetable_config" action="action_vidya_period" sequence="20"/>
</odoo>
