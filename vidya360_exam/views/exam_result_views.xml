<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_exam_result_list" model="ir.ui.view">
        <field name="name">vidya.exam.result.list</field>
        <field name="model">vidya.exam.result</field>
        <field name="arch" type="xml">
            <list string="Exam Results">
                <field name="name"/>
                <field name="student_id"/>
                <field name="exam_id"/>
                <field name="subject_id"/>
                <field name="marks_obtained"/>
                <field name="maximum_marks"/>
                <field name="grade"/>
            </list>
        </field>
    </record>

    <record id="view_vidya_exam_result_form" model="ir.ui.view">
        <field name="name">vidya.exam.result.form</field>
        <field name="model">vidya.exam.result</field>
        <field name="arch" type="xml">
            <form string="Exam Result">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="schedule_id"/>
                            <field name="exam_id"/>
                            <field name="subject_id"/>
                        </group>
                        <group>
                            <field name="marks_obtained"/>
                            <field name="maximum_marks"/>
                            <field name="grade"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Remarks" name="remarks">
                            <field name="remarks" placeholder="Teacher's remarks..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_vidya_exam_result" model="ir.actions.act_window">
        <field name="name">Results</field>
        <field name="res_model">vidya.exam.result</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
