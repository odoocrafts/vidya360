<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_exam_schedule_list" model="ir.ui.view">
        <field name="name">vidya.exam.schedule.list</field>
        <field name="model">vidya.exam.schedule</field>
        <field name="arch" type="xml">
            <list string="Exam Schedules">
                <field name="exam_id"/>
                <field name="subject_id"/>
                <field name="class_level_id"/>
                <field name="section_id"/>
                <field name="date"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="view_vidya_exam_schedule_form" model="ir.ui.view">
        <field name="name">vidya.exam.schedule.form</field>
        <field name="model">vidya.exam.schedule</field>
        <field name="arch" type="xml">
            <form string="Exam Schedule">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="exam_id"/>
                            <field name="subject_id"/>
                            <field name="maximum_marks"/>
                        </group>
                        <group>
                            <field name="class_level_id"/>
                            <field name="section_id"/>
                            <field name="date"/>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_vidya_exam_schedule_calendar" model="ir.ui.view">
        <field name="name">vidya.exam.schedule.calendar</field>
        <field name="model">vidya.exam.schedule</field>
        <field name="arch" type="xml">
            <calendar string="Exam Schedule" date_start="date" color="class_level_id" mode="month">
                <field name="subject_id"/>
                <field name="class_level_id"/>
            </calendar>
        </field>
    </record>

    <record id="action_vidya_exam_schedule" model="ir.actions.act_window">
        <field name="name">Exam Schedules</field>
        <field name="res_model">vidya.exam.schedule</field>
        <field name="view_mode">calendar,list,form</field>
    </record>
</odoo>
