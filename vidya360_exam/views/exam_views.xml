<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_exam_list" model="ir.ui.view">
        <field name="name">vidya.exam.list</field>
        <field name="model">vidya.exam</field>
        <field name="arch" type="xml">
            <list string="Exams">
                <field name="name"/>
                <field name="academic_year_id"/>
                <field name="term_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'scheduled'" decoration-success="state == 'ongoing'" decoration-muted="state == 'completed'"/>
            </list>
        </field>
    </record>

    <record id="view_vidya_exam_form" model="ir.ui.view">
        <field name="name">vidya.exam.form</field>
        <field name="model">vidya.exam</field>
        <field name="arch" type="xml">
            <form string="Examination">
                <header>
                    <button name="action_schedule" string="Schedule" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_ongoing" string="Start Exam" type="object" class="oe_highlight" invisible="state != 'scheduled'"/>
                    <button name="action_complete" string="Mark Completed" type="object" invisible="state != 'ongoing'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,scheduled,ongoing,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="E.g., Mid-Term 2026"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="academic_year_id"/>
                            <field name="term_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_vidya_exam" model="ir.actions.act_window">
        <field name="name">Exams</field>
        <field name="res_model">vidya.exam</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
