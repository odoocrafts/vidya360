<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_event_form" model="ir.ui.view">
        <field name="name">vidya.event.form</field>
        <field name="model">vidya.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" string="Event Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Summer Break"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="event_type"/>
                            <field name="all_day"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_vidya_event_tree" model="ir.ui.view">
        <field name="name">vidya.event.tree</field>
        <field name="model">vidya.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="event_type"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="location"/>
            </list>
        </field>
    </record>

    <record id="view_vidya_event_calendar" model="ir.ui.view">
        <field name="name">vidya.event.calendar</field>
        <field name="model">vidya.event</field>
        <field name="arch" type="xml">
            <calendar string="School Calendar" date_start="start_date" date_stop="end_date" color="event_type" all_day="all_day">
                <field name="name"/>
                <field name="event_type"/>
            </calendar>
        </field>
    </record>

    <record id="action_vidya_event" model="ir.actions.act_window">
        <field name="name">School Calendar</field>
        <field name="res_model">vidya.event</field>
        <field name="view_mode">calendar,list,form</field>
    </record>
</odoo>
