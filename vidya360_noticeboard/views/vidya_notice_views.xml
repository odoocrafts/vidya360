<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_notice_form" model="ir.ui.view">
        <field name="name">vidya.notice.form</field>
        <field name="model">vidya.notice</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" string="Publish" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <button name="action_archive" string="Archive" type="object" invisible="state != 'published'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" string="Notice Title"/>
                        <h1>
                            <field name="name" placeholder="e.g. Annual Sports Day Announcement" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="audience" readonly="state != 'draft'"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="date_posted" readonly="state != 'draft'"/>
                            <field name="date_expiration" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content" name="content">
                            <field name="content" readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_vidya_notice_tree" model="ir.ui.view">
        <field name="name">vidya.notice.tree</field>
        <field name="model">vidya.notice</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'draft'" decoration-success="state == 'published'" decoration-muted="state == 'archived'">
                <field name="name"/>
                <field name="audience"/>
                <field name="date_posted"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'published'"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_notice" model="ir.actions.act_window">
        <field name="name">Notices</field>
        <field name="res_model">vidya.notice</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
