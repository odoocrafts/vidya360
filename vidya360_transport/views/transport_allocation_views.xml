<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_transport_allocation_list" model="ir.ui.view">
        <field name="name">vidya.transport.allocation.list</field>
        <field name="model">vidya.transport.allocation</field>
        <field name="arch" type="xml">
            <list string="Transport Allocations">
                <field name="name"/>
                <field name="occupant_type"/>
                <field name="student_id" invisible="occupant_type != 'student'"/>
                <field name="staff_id" invisible="occupant_type != 'staff'"/>
                <field name="route_id"/>
                <field name="vehicle_id"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'active'" decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_vidya_transport_allocation_form" model="ir.ui.view">
        <field name="name">vidya.transport.allocation.form</field>
        <field name="model">vidya.transport.allocation</field>
        <field name="arch" type="xml">
            <form string="Transport Allocation">
                <header>
                    <button name="action_activate" string="Activate" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="occupant_type" widget="radio"/>
                            <field name="student_id" invisible="occupant_type != 'student'" required="occupant_type == 'student'"/>
                            <field name="staff_id" invisible="occupant_type != 'staff'" required="occupant_type == 'staff'"/>
                        </group>
                        <group>
                            <field name="route_id"/>
                            <field name="vehicle_id"/>
                            <field name="start_date"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_vidya_transport_allocation" model="ir.actions.act_window">
        <field name="name">Allocations</field>
        <field name="res_model">vidya.transport.allocation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
