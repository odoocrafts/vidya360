<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_vidya_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.vidya.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Vidya 360 Education">
                    <group>
                        <group>
                            <field name="vidya_staff_type"/>
                            <field name="is_teacher" invisible="1"/>
                        </group>
                        <group invisible="not is_teacher">
                            <field name="qualified_subject_ids" widget="many2many_tags"/>
                        </group>
                        <group invisible="is_teacher">
                            <field name="duty_assignments"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
