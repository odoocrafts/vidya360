<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_certificate_request_form" model="ir.ui.view">
        <field name="name">vidya.certificate.request.form</field>
        <field name="model">vidya.certificate.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve" string="Approve" type="object" invisible="state != 'draft'" groups="vidya360_core.group_vidya_admin"/>
                    <button name="action_issue" string="Mark as Issued" type="object" invisible="state != 'approved'" class="oe_highlight"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state not in ('draft', 'approved')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,issued,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="student_id" readonly="state != 'draft'"/>
                            <field name="certificate_type" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="date_request" readonly="state != 'draft'"/>
                            <field name="date_issue" readonly="1"/>
                            <field name="purpose" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Certificate Details">
                            <group>
                                <group>
                                    <field name="academic_year_id" invisible="certificate_type not in ('bonafide', 'study', 'course_completion')" readonly="state != 'draft'"/>
                                    <field name="class_id" invisible="certificate_type not in ('bonafide', 'study', 'course_completion')" readonly="state != 'draft'"/>
                                    
                                    <field name="character_evaluation" invisible="certificate_type not in ('conduct', 'character')" required="certificate_type in ('conduct', 'character')" readonly="state != 'draft'"/>
                                    
                                    <field name="currency_id" invisible="1"/>
                                    <field name="fee_amount_paid" invisible="certificate_type != 'fee_paid'" required="certificate_type == 'fee_paid'" readonly="state != 'draft'"/>
                                    <field name="financial_year" invisible="certificate_type != 'fee_paid'" required="certificate_type == 'fee_paid'" readonly="state != 'draft'"/>
                                </group>
                                <group>
                                    <field name="reason_for_leaving" invisible="certificate_type != 'tc'" required="certificate_type == 'tc'" readonly="state != 'draft'"/>
                                    <field name="last_date_of_attendance" invisible="certificate_type != 'tc'" required="certificate_type == 'tc'" readonly="state != 'draft'"/>
                                    <field name="promoted_to_class" invisible="certificate_type != 'tc'" readonly="state != 'draft'"/>
                                    <field name="all_dues_paid" invisible="certificate_type != 'tc'" readonly="state != 'draft'"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_certificate_request_tree" model="ir.ui.view">
        <field name="name">vidya.certificate.request.tree</field>
        <field name="model">vidya.certificate.request</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="certificate_type"/>
                <field name="date_request"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'approved'" decoration-success="state == 'issued'" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_certificate_request" model="ir.actions.act_window">
        <field name="name">Certificate Requests</field>
        <field name="res_model">vidya.certificate.request</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
