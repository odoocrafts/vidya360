<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_hostel_building_form" model="ir.ui.view">
        <field name="name">vidya.hostel.building.form</field>
        <field name="model">vidya.hostel.building</field>
        <field name="arch" type="xml">
            <form string="Hostel Building">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Building Name (e.g. Block A)"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="building_type"/>
                            <field name="warden_id"/>
                        </group>
                        <group>
                            <field name="total_capacity"/>
                            <field name="current_occupancy"/>
                        </group>
                    </group>
                    <group>
                        <field name="address"/>
                    </group>
                    <notebook>
                        <page string="Rooms" name="rooms">
                            <field name="room_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="room_type"/>
                                    <field name="capacity"/>
                                    <field name="current_occupancy"/>
                                    <field name="available_beds"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_hostel_building_tree" model="ir.ui.view">
        <field name="name">vidya.hostel.building.tree</field>
        <field name="model">vidya.hostel.building</field>
        <field name="arch" type="xml">
            <list string="Hostel Buildings">
                <field name="name"/>
                <field name="building_type"/>
                <field name="warden_id"/>
                <field name="total_capacity"/>
                <field name="current_occupancy"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_hostel_building" model="ir.actions.act_window">
        <field name="name">Hostel Buildings</field>
        <field name="res_model">vidya.hostel.building</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create the first Hostel Building!
            </p>
        </field>
    </record>
</odoo>
