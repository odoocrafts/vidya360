<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_hostel_room_form" model="ir.ui.view">
        <field name="name">vidya.hostel.room.form</field>
        <field name="model">vidya.hostel.room</field>
        <field name="arch" type="xml">
            <form string="Hostel Room">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Room Number"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="building_id"/>
                            <field name="category"/>
                            <field name="room_type"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="current_occupancy"/>
                            <field name="available_beds"/>
                            <field name="rent_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Allocations" name="allocations">
                            <field name="allocation_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="occupant_type"/>
                                    <field name="student_id" invisible="occupant_type != 'student'"/>
                                    <field name="staff_id" invisible="occupant_type != 'staff'"/>
                                    <field name="start_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_hostel_room_tree" model="ir.ui.view">
        <field name="name">vidya.hostel.room.tree</field>
        <field name="model">vidya.hostel.room</field>
        <field name="arch" type="xml">
            <list string="Hostel Rooms">
                <field name="name"/>
                <field name="building_id"/>
                <field name="category"/>
                <field name="capacity"/>
                <field name="current_occupancy"/>
                <field name="available_beds"/>
                <field name="rent_amount"/>
            </list>
        </field>
    </record>

    <record id="view_vidya_hostel_room_kanban" model="ir.ui.view">
        <field name="name">vidya.hostel.room.kanban</field>
        <field name="model">vidya.hostel.room</field>
        <field name="arch" type="xml">
            <kanban default_group_by="building_id" class="o_kanban_mobile">
                <field name="name"/>
                <field name="building_id"/>
                <field name="available_beds"/>
                <field name="capacity"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        Room: <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><field name="category"/>, <field name="room_type"/></div>
                                <div>Available: <field name="available_beds"/> / <field name="capacity"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_vidya_hostel_room" model="ir.actions.act_window">
        <field name="name">Hostel Rooms</field>
        <field name="res_model">vidya.hostel.room</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create rooms for your hostels!
            </p>
        </field>
    </record>
</odoo>
