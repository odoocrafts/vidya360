<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vidya_hostel_allocation_form" model="ir.ui.view">
        <field name="name">vidya.hostel.allocation.form</field>
        <field name="model">vidya.hostel.allocation</field>
        <field name="arch" type="xml">
            <form string="Hostel Allocation">
                <header>
                    <button name="action_allocate" string="Allocate" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_vacate" string="Vacate" type="object" class="btn-danger" invisible="state != 'allocated'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,allocated,vacated"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="occupant_type"/>
                            <field name="student_id" invisible="occupant_type != 'student'" required="occupant_type == 'student'"/>
                            <field name="staff_id" invisible="occupant_type != 'staff'" required="occupant_type == 'staff'"/>
                        </group>
                        <group>
                            <field name="room_id"/>
                            <field name="building_id"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_vidya_hostel_allocation_tree" model="ir.ui.view">
        <field name="name">vidya.hostel.allocation.tree</field>
        <field name="model">vidya.hostel.allocation</field>
        <field name="arch" type="xml">
            <list string="Hostel Allocations">
                <field name="name"/>
                <field name="occupant_type"/>
                <field name="student_id"/>
                <field name="staff_id"/>
                <field name="room_id"/>
                <field name="start_date"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'allocated'" decoration-muted="state == 'vacated'"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_hostel_allocation" model="ir.actions.act_window">
        <field name="name">Room Allocations</field>
        <field name="res_model">vidya.hostel.allocation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Allocate the first room to a student or staff!
            </p>
        </field>
    </record>
</odoo>
