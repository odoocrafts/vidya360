<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fee Group -->
    <record id="view_vidya_fee_group_form" model="ir.ui.view">
        <field name="name">vidya.fee.group.form</field>
        <field name="model">vidya.fee.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="sequence"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vidya_fee_group" model="ir.actions.act_window">
        <field name="name">Fee Groups</field>
        <field name="res_model">vidya.fee.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Fee Structure -->
    <record id="view_vidya_fee_structure_form" model="ir.ui.view">
        <field name="name">vidya.fee.structure.form</field>
        <field name="model">vidya.fee.structure</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="academic_year_id"/>
                        </group>
                        <group>
                            <field name="class_id"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Fee Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="fee_group_id"/>
                                    <field name="amount"/>
                                    <field name="frequency"/>
                                    <field name="product_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vidya_fee_structure_tree" model="ir.ui.view">
        <field name="name">vidya.fee.structure.tree</field>
        <field name="model">vidya.fee.structure</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="academic_year_id"/>
                <field name="class_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_vidya_fee_structure" model="ir.actions.act_window">
        <field name="name">Fee Structures</field>
        <field name="res_model">vidya.fee.structure</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_vidya360_fee_group" name="Fee Groups" parent="menu_vidya360_fee_config" action="action_vidya_fee_group" sequence="10"/>
    <menuitem id="menu_vidya360_fee_structure" name="Fee Structures" parent="menu_vidya360_fee_config" action="action_vidya_fee_structure" sequence="20"/>
</odoo>
